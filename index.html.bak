<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
<title>Black Gold Blitz</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
html, body {
  width: 100%; height: 100%;
  overflow: hidden;
  background: #000;
  touch-action: none;
  -webkit-touch-callout: none;
  -webkit-user-select: none;
  user-select: none;
  font-family: 'Segoe UI', system-ui, sans-serif;
}
canvas {
  display: block;
  width: 100%; height: 100%;
}
</style>
</head>
<body>
<canvas id="game"></canvas>
<script>
"use strict";

/* ===== CONSTANTS ===== */
const WORLD_W = 4000;
const WORLD_H = 4000;
const TILE = 64;
const OIL_START = 300;
const OIL_MAX = 2000;
const WANTED_THRESHOLDS = [0, 300, 600, 1000, 1500];
const PLAYER_BASE_SPEED = 4.5;
const PLAYER_MAX_SPEED_PENALTY = 1.5;
const FIRE_COOLDOWN_MS = 180;
const HOMING_COOLDOWN_MS = 600;
const RIG_COUNT = 8;
const CAPTURE_RADIUS = 70;
const CAPTURE_TIME = 2.0;
const OIL_PER_SECOND = 8;
const DRONE_DAMAGE = 15;
const PLANE_DAMAGE = 25;
const CHOPPER_DAMAGE = 20;
const BULLET_SPEED = 9;
const HOMING_SPEED = 5;
const HOMING_TURN = 0.06;
const MAX_DELTA_TIME = 0.05;
const ENEMY_SPAWN_DISTANCE = 400;
const UPGRADE_INTERVAL = 500;
const DUAL_CANNON_THRESHOLD = 500;
const HOMING_THRESHOLD = 1000;

/* ===== CANVAS SETUP ===== */
const canvas = document.getElementById("game");
const ctx = canvas.getContext("2d");
let W, H;
function resize() {
  W = canvas.width = window.innerWidth;
  H = canvas.height = window.innerHeight;
}
window.addEventListener("resize", resize);
resize();

/* ===== UTILS ===== */
function dist(a, b) { return Math.hypot(a.x - b.x, a.y - b.y); }
function angle(a, b) { return Math.atan2(b.y - a.y, b.x - a.x); }
function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }
function rand(lo, hi) { return lo + Math.random() * (hi - lo); }
function randInt(lo, hi) { return Math.floor(rand(lo, hi + 1)); }
function lerp(a, b, t) { return a + (b - a) * t; }

/* ===== SCREEN SHAKE ===== */
let shakeAmount = 0;
function addShake(amount) { shakeAmount = Math.min(shakeAmount + amount, 15); }

/* ===== INPUT ===== */
const keys = {};
window.addEventListener("keydown", e => { keys[e.code] = true; });
window.addEventListener("keyup", e => { keys[e.code] = false; });

let touchMove = { x: 0, y: 0, active: false };
let touchFire = false;
let touchMissile = false;
let joystickCenter = null;
const JOYSTICK_RADIUS = 60;

canvas.addEventListener("touchstart", handleTouch, { passive: false });
canvas.addEventListener("touchmove", handleTouch, { passive: false });
canvas.addEventListener("touchend", handleTouchEnd, { passive: false });
canvas.addEventListener("touchcancel", handleTouchEnd, { passive: false });

function handleTouch(e) {
  e.preventDefault();
  if (gameState === "upgrade") { handleUpgradeTouch(e); return; }
  if (gameState !== "playing") return;
  for (const t of e.touches) {
    if (t.clientX < W * 0.5) {
      if (!joystickCenter) joystickCenter = { x: t.clientX, y: t.clientY };
      const dx = t.clientX - joystickCenter.x;
      const dy = t.clientY - joystickCenter.y;
      const d = Math.hypot(dx, dy);
      if (d > 5) {
        touchMove.x = dx / Math.max(d, JOYSTICK_RADIUS);
        touchMove.y = dy / Math.max(d, JOYSTICK_RADIUS);
        touchMove.active = true;
      }
    } else {
      if (t.clientY < H * 0.5) touchMissile = true;
      else touchFire = true;
    }
  }
}

function handleTouchEnd(e) {
  e.preventDefault();
  if (e.touches.length === 0) {
    touchMove = { x: 0, y: 0, active: false };
    joystickCenter = null;
    touchFire = false;
    touchMissile = false;
  } else {
    let hasLeft = false, hasRightLow = false, hasRightHigh = false;
    for (const t of e.touches) {
      if (t.clientX < W * 0.5) hasLeft = true;
      else if (t.clientY >= H * 0.5) hasRightLow = true;
      else hasRightHigh = true;
    }
    if (!hasLeft) { touchMove = { x: 0, y: 0, active: false }; joystickCenter = null; }
    touchFire = hasRightLow;
    touchMissile = hasRightHigh;
  }
}

let mouseX = W / 2, mouseY = H / 2;
let mouseDown = false;
let rightMouseDown = false;
canvas.addEventListener("mousemove", e => { mouseX = e.clientX; mouseY = e.clientY; });
canvas.addEventListener("mousedown", e => {
  if (e.button === 0) mouseDown = true;
  if (e.button === 2) rightMouseDown = true;
});
canvas.addEventListener("mouseup", e => {
  if (e.button === 0) mouseDown = false;
  if (e.button === 2) rightMouseDown = false;
});
canvas.addEventListener("contextmenu", e => e.preventDefault());

/* ===== CAMERA ===== */
const camera = { x: 0, y: 0 };
function updateCamera(target) {
  camera.x = clamp(target.x - W / 2, 0, Math.max(0, WORLD_W - W));
  camera.y = clamp(target.y - H / 2, 0, Math.max(0, WORLD_H - H));
}

/* ===== PARTICLES ===== */
const particles = [];
function spawnParticle(x, y, vx, vy, life, r, color, type) {
  particles.push({ x, y, vx, vy, life, maxLife: life, r, color, type: type || "circle" });
}
function spawnExplosion(x, y, color, count) {
  for (let i = 0; i < count; i++) {
    const a = Math.random() * Math.PI * 2;
    const sp = rand(1, 5);
    spawnParticle(x, y, Math.cos(a) * sp, Math.sin(a) * sp, rand(0.3, 0.9), rand(2, 6), color, "fire");
  }
  for (let i = 0; i < Math.floor(count / 2); i++) {
    const a = Math.random() * Math.PI * 2;
    const sp = rand(0.5, 2);
    spawnParticle(x, y, Math.cos(a) * sp, Math.sin(a) * sp - 0.5, rand(0.5, 1.5), rand(4, 10), "#333", "smoke");
  }
}
function spawnOilSpill(x, y) {
  for (let i = 0; i < 12; i++) {
    const a = Math.random() * Math.PI * 2;
    const sp = rand(0.5, 2.5);
    spawnParticle(x, y, Math.cos(a) * sp, Math.sin(a) * sp, rand(0.5, 1.5), rand(3, 8), "#1a0a00", "oil");
  }
}
function spawnMuzzleFlash(x, y, a) {
  for (let i = 0; i < 4; i++) {
    const sa = a + rand(-0.3, 0.3);
    const sp = rand(3, 7);
    spawnParticle(x, y, Math.cos(sa) * sp, Math.sin(sa) * sp, rand(0.05, 0.15), rand(2, 4), "#ffee88", "fire");
  }
}
function spawnEngineTrail(x, y, a) {
  const sa = a + Math.PI + rand(-0.2, 0.2);
  const sp = rand(0.5, 1.5);
  spawnParticle(x, y, Math.cos(sa) * sp, Math.sin(sa) * sp, rand(0.2, 0.5), rand(1, 3), "#557799", "smoke");
}

/* ===== FLOATING TEXT ===== */
const floatingTexts = [];
function spawnFloatingText(x, y, text, color) {
  floatingTexts.push({ x, y, text, color, life: 1.5, maxLife: 1.5 });
}

/* ===== UPGRADE SYSTEM ===== */
const UPGRADES = {
  speed_boost: { name: "Afterburner", desc: "+20% speed", icon: "\u26A1", color: "#44ccff", maxLevel: 3,
    apply: (l) => { upgradeStats.speedMult = 1 + l * 0.2; } },
  armor: { name: "Reinforced Hull", desc: "-25% damage", icon: "\uD83D\uDEE1\uFE0F", color: "#4488ff", maxLevel: 3,
    apply: (l) => { upgradeStats.armorMult = 1 - l * 0.2; } },
  rapid_fire: { name: "Rapid Fire", desc: "+30% fire rate", icon: "\uD83D\uDD25", color: "#ff8844", maxLevel: 3,
    apply: (l) => { upgradeStats.fireRateMult = 1 - l * 0.2; } },
  spread_shot: { name: "Spread Shot", desc: "Spread pattern", icon: "\uD83C\uDF1F", color: "#ffcc00", maxLevel: 2,
    apply: (l) => { upgradeStats.spreadCount = 1 + l * 2; } },
  oil_magnet: { name: "Oil Magnet", desc: "+50% oil gain", icon: "\uD83E\uDDF2", color: "#88ff44", maxLevel: 3,
    apply: (l) => { upgradeStats.oilMult = 1 + l * 0.5; } },
  shield: { name: "Energy Shield", desc: "Auto-shield 15s", icon: "\uD83D\uDD2E", color: "#aa44ff", maxLevel: 2,
    apply: (l) => { upgradeStats.shieldInterval = Math.max(8, 15 - l * 4); upgradeStats.hasShield = true; } },
  emp: { name: "EMP Blast", desc: "Stun on damage", icon: "\uD83D\uDCAB", color: "#44ffff", maxLevel: 2,
    apply: (l) => { upgradeStats.empRadius = 80 + l * 60; upgradeStats.hasEmp = true; } },
  critical: { name: "Critical Strike", desc: "+15% crit (2x)", icon: "\uD83D\uDCA5", color: "#ff4444", maxLevel: 3,
    apply: (l) => { upgradeStats.critChance = l * 0.15; } },
  repair: { name: "Nano Repair", desc: "+3 oil/sec regen", icon: "\uD83D\uDC9A", color: "#44ff88", maxLevel: 3,
    apply: (l) => { upgradeStats.regenRate = l * 3; } },
  missile_boost: { name: "Warhead Upgrade", desc: "+40% missile dmg", icon: "\uD83D\uDE80", color: "#ff6600", maxLevel: 2,
    apply: (l) => { upgradeStats.missileDmgMult = 1 + l * 0.4; upgradeStats.missileSpeedMult = 1 + l * 0.3; } }
};

let upgradeStats = {};
let upgradeLevels = {};
let upgradeChoices = [];
let nextUpgradeScore = UPGRADE_INTERVAL;
let totalUpgrades = 0;

function resetUpgrades() {
  upgradeStats = {
    speedMult: 1, armorMult: 1, fireRateMult: 1, spreadCount: 1,
    oilMult: 1, hasShield: false, shieldInterval: 15, shieldTimer: 0,
    empRadius: 0, hasEmp: false, critChance: 0, regenRate: 0,
    missileDmgMult: 1, missileSpeedMult: 1
  };
  upgradeLevels = {};
  nextUpgradeScore = UPGRADE_INTERVAL;
  totalUpgrades = 0;
}

function getUpgradeChoices() {
  const pool = Object.keys(UPGRADES).filter(k => (upgradeLevels[k] || 0) < UPGRADES[k].maxLevel);
  const choices = [];
  const p = [...pool];
  for (let i = 0; i < Math.min(3, p.length); i++) {
    const idx = randInt(0, p.length - 1);
    choices.push(p[idx]);
    p.splice(idx, 1);
  }
  return choices;
}

function applyUpgrade(key) {
  upgradeLevels[key] = (upgradeLevels[key] || 0) + 1;
  UPGRADES[key].apply(upgradeLevels[key]);
  totalUpgrades++;
}

function handleUpgradeTouch(e) {
  for (const t of e.changedTouches) handleUpgradeClick(t.clientX, t.clientY);
}

function handleUpgradeClick(mx, my) {
  if (upgradeChoices.length === 0) return;
  const cardW = Math.min(200, W * 0.28);
  const cardH = Math.min(260, H * 0.45);
  const gap = Math.min(30, W * 0.03);
  const totalW = upgradeChoices.length * cardW + (upgradeChoices.length - 1) * gap;
  const startX = (W - totalW) / 2;
  const startY = (H - cardH) / 2;
  for (let i = 0; i < upgradeChoices.length; i++) {
    const cx = startX + i * (cardW + gap);
    if (mx >= cx && mx <= cx + cardW && my >= startY && my <= startY + cardH) {
      applyUpgrade(upgradeChoices[i]);
      upgradeChoices = [];
      gameState = "playing";
      return;
    }
  }
}

/* ===== GAME STATE ===== */
let gameState = "title";
let score = 0;
let waveTimer = 0;
let wantedLevel = 0;
let time = 0;

/* ===== PLAYER ===== */
const player = {
  x: WORLD_W / 2, y: WORLD_H / 2, vx: 0, vy: 0,
  angle: -Math.PI / 2, oil: OIL_START,
  fireCooldown: 0, homingCooldown: 0, invincible: 0,
  rotorAngle: 0, tailRotorAngle: 0, alive: true,
  engineGlow: 0, shieldActive: false, shieldTimer: 0,
};

function resetPlayer() {
  Object.assign(player, {
    x: WORLD_W / 2, y: WORLD_H / 2, vx: 0, vy: 0,
    angle: -Math.PI / 2, oil: OIL_START,
    fireCooldown: 0, homingCooldown: 0, invincible: 0,
    rotorAngle: 0, tailRotorAngle: 0, alive: true,
    engineGlow: 0, shieldActive: false, shieldTimer: 0,
  });
}

/* ===== PROJECTILES ===== */
const bullets = [];
const enemyBullets = [];
const homingMissiles = [];

function fireBullet() {
  const hasDual = player.oil >= DUAL_CANNON_THRESHOLD;
  const spreadCount = upgradeStats.spreadCount;
  const offsets = hasDual ? [-8, 8] : [0];
  const spreadAngle = 0.12;
  for (const off of offsets) {
    const perpAngle = player.angle + Math.PI / 2;
    const bx = player.x + Math.cos(perpAngle) * off;
    const by = player.y + Math.sin(perpAngle) * off;
    if (spreadCount > 1) {
      const half = (spreadCount - 1) / 2;
      for (let s = 0; s < spreadCount; s++) {
        const a = player.angle + (s - half) * spreadAngle;
        const isCrit = Math.random() < upgradeStats.critChance;
        bullets.push({ x: bx, y: by, vx: Math.cos(a) * BULLET_SPEED, vy: Math.sin(a) * BULLET_SPEED, life: 1.5, damage: isCrit ? 40 : 20, crit: isCrit });
      }
    } else {
      const isCrit = Math.random() < upgradeStats.critChance;
      bullets.push({ x: bx, y: by, vx: Math.cos(player.angle) * BULLET_SPEED, vy: Math.sin(player.angle) * BULLET_SPEED, life: 1.5, damage: isCrit ? 40 : 20, crit: isCrit });
    }
    spawnMuzzleFlash(bx, by, player.angle);
  }
}

function fireHoming() {
  if (player.oil < HOMING_THRESHOLD) return false;
  const target = findNearestEnemy(player);
  if (!target) return false;
  homingMissiles.push({
    x: player.x, y: player.y, angle: player.angle,
    speed: HOMING_SPEED * upgradeStats.missileSpeedMult, target,
    life: 4, damage: 80 * upgradeStats.missileDmgMult,
  });
  return true;
}

function findNearestEnemy(from) {
  let best = null, bestD = Infinity;
  for (const e of enemies) { const d = dist(from, e); if (d < bestD) { bestD = d; best = e; } }
  return best;
}

/* ===== OIL RIGS ===== */
const rigs = [];
function initRigs() {
  rigs.length = 0;
  for (let i = 0; i < RIG_COUNT; i++) {
    rigs.push({ x: rand(300, WORLD_W - 300), y: rand(300, WORLD_H - 300),
      owner: "neutral", captureProgress: 0, hp: 100, maxHp: 100,
      flamePhase: Math.random() * Math.PI * 2, craneAngle: Math.random() * Math.PI * 2 });
  }
}

/* ===== ENEMIES ===== */
const enemies = [];
function spawnDrone(x, y) {
  enemies.push({ type: "drone", x, y, vx: 0, vy: 0, hp: 30, maxHp: 30, angle: 0,
    speed: 2.5 + wantedLevel * 0.3, damage: DRONE_DAMAGE, radius: 14, scoreValue: 50,
    rotorAngle: Math.random() * Math.PI * 2, stunTimer: 0 });
}
function spawnPlane(edge) {
  let x, y, ang;
  switch (edge) {
    case 0: x = rand(0, WORLD_W); y = -40; ang = Math.PI / 2 + rand(-0.3, 0.3); break;
    case 1: x = WORLD_W + 40; y = rand(0, WORLD_H); ang = Math.PI + rand(-0.3, 0.3); break;
    case 2: x = rand(0, WORLD_W); y = WORLD_H + 40; ang = -Math.PI / 2 + rand(-0.3, 0.3); break;
    default: x = -40; y = rand(0, WORLD_H); ang = rand(-0.3, 0.3); break;
  }
  enemies.push({ type: "plane", x, y, vx: 0, vy: 0, hp: 50, maxHp: 50, angle: ang,
    speed: 5 + wantedLevel * 0.4, damage: PLANE_DAMAGE, radius: 18, scoreValue: 100,
    fireCooldown: 0, propAngle: 0, stunTimer: 0 });
}
function spawnChopper(x, y) {
  enemies.push({ type: "chopper", x, y, vx: 0, vy: 0, hp: 80, maxHp: 80, angle: 0,
    speed: 2 + wantedLevel * 0.2, damage: CHOPPER_DAMAGE, radius: 18, scoreValue: 150,
    fireCooldown: 0, rotorAngle: 0, tailRotorAngle: 0, stunTimer: 0 });
}

/* ===== WAVE SPAWNER ===== */
function spawnWave(dt) {
  waveTimer -= dt;
  if (waveTimer > 0) return;
  wantedLevel = 0;
  for (let i = WANTED_THRESHOLDS.length - 1; i >= 0; i--) {
    if (player.oil >= WANTED_THRESHOLDS[i]) { wantedLevel = i; break; }
  }
  waveTimer = Math.max(1.0, 3.5 - wantedLevel * 0.5);
  const spawnAngle = Math.random() * Math.PI * 2;
  const sx = clamp(player.x + Math.cos(spawnAngle) * ENEMY_SPAWN_DISTANCE, 50, WORLD_W - 50);
  const sy = clamp(player.y + Math.sin(spawnAngle) * ENEMY_SPAWN_DISTANCE, 50, WORLD_H - 50);
  const roll = Math.random();
  if (roll < 0.45) {
    for (let i = 0; i < 2 + wantedLevel; i++) spawnDrone(sx + rand(-40, 40), sy + rand(-40, 40));
  } else if (roll < 0.75) {
    spawnPlane(randInt(0, 3));
  } else {
    spawnChopper(sx, sy);
  }
  if (wantedLevel >= 3) spawnChopper(sx + 60, sy + 60);
  if (wantedLevel >= 4) { spawnPlane(randInt(0, 3)); spawnPlane(randInt(0, 3)); }
}

/* ===== UPDATE ===== */
function update(dt) {
  time += dt;
  let ix = 0, iy = 0;
  if (keys["KeyW"] || keys["ArrowUp"]) iy -= 1;
  if (keys["KeyS"] || keys["ArrowDown"]) iy += 1;
  if (keys["KeyA"] || keys["ArrowLeft"]) ix -= 1;
  if (keys["KeyD"] || keys["ArrowRight"]) ix += 1;
  if (touchMove.active) { ix = touchMove.x; iy = touchMove.y; }
  const inputLen = Math.hypot(ix, iy);
  if (inputLen > 0.01) { ix /= inputLen; iy /= inputLen; }
  const speed = Math.max(1, PLAYER_BASE_SPEED * upgradeStats.speedMult - (player.oil / OIL_MAX) * PLAYER_MAX_SPEED_PENALTY);
  player.vx = lerp(player.vx, ix * speed, 0.15);
  player.vy = lerp(player.vy, iy * speed, 0.15);
  player.x = clamp(player.x + player.vx, 20, WORLD_W - 20);
  player.y = clamp(player.y + player.vy, 20, WORLD_H - 20);
  player.engineGlow = lerp(player.engineGlow, inputLen > 0.1 ? 1 : 0.2, 0.1);
  if (inputLen > 0.1 && Math.random() < 0.5) spawnEngineTrail(player.x - Math.cos(player.angle) * 14, player.y - Math.sin(player.angle) * 14, player.angle);
  if (touchMove.active && inputLen > 0.01) player.angle = Math.atan2(iy, ix);
  else if (!touchMove.active) player.angle = Math.atan2(mouseY + camera.y - player.y, mouseX + camera.x - player.x);
  player.rotorAngle += dt * 25;
  player.tailRotorAngle += dt * 35;
  if (player.invincible > 0) player.invincible -= dt;
  if (upgradeStats.hasShield) { player.shieldTimer -= dt; if (player.shieldTimer <= 0) { player.shieldActive = true; player.shieldTimer = upgradeStats.shieldInterval; } }
  if (upgradeStats.regenRate > 0) player.oil = Math.min(OIL_MAX, player.oil + upgradeStats.regenRate * dt);

  player.fireCooldown -= dt;
  player.homingCooldown -= dt;
  const wantFire = keys["Space"] || mouseDown || touchFire;
  const wantMissile = keys["KeyE"] || rightMouseDown || touchMissile;
  if (wantFire && player.fireCooldown <= 0) { fireBullet(); player.fireCooldown = (FIRE_COOLDOWN_MS / 1000) * upgradeStats.fireRateMult; }
  if (wantMissile && player.homingCooldown <= 0 && player.oil >= HOMING_THRESHOLD) { if (fireHoming()) player.homingCooldown = HOMING_COOLDOWN_MS / 1000; }

  for (const rig of rigs) {
    if (rig.hp <= 0) continue;
    rig.flamePhase += dt * 4;
    rig.craneAngle += dt * 0.8;
    if (dist(player, rig) < CAPTURE_RADIUS && rig.owner !== "player") {
      rig.captureProgress += dt;
      if (rig.captureProgress >= CAPTURE_TIME) { rig.owner = "player"; rig.captureProgress = 0; score += 200; spawnFloatingText(rig.x, rig.y - 30, "+200 CAPTURED", "#44ff88"); }
    } else if (rig.owner !== "player") { rig.captureProgress = Math.max(0, rig.captureProgress - dt * 0.5); }
    if (rig.owner === "player" && player.oil < OIL_MAX) player.oil = Math.min(OIL_MAX, player.oil + OIL_PER_SECOND * upgradeStats.oilMult * dt);
  }

  spawnWave(dt);

  for (let i = enemies.length - 1; i >= 0; i--) {
    const e = enemies[i];
    if (e.stunTimer > 0) { e.stunTimer -= dt; if (e.type === "drone") e.rotorAngle += dt * 10; continue; }
    if (e.type === "drone") {
      e.rotorAngle += dt * 30;
      const a = angle(e, player);
      e.vx = lerp(e.vx, Math.cos(a) * e.speed, 0.08);
      e.vy = lerp(e.vy, Math.sin(a) * e.speed, 0.08);
      e.x += e.vx; e.y += e.vy;
      e.angle = Math.atan2(e.vy, e.vx);
      if (dist(e, player) < 28 && player.invincible <= 0) { damagePlayer(e.damage); e.hp = 0; spawnExplosion(e.x, e.y, "#ff5500", 12); addShake(4); }
    }
    if (e.type === "plane") {
      e.propAngle = (e.propAngle || 0) + dt * 40;
      e.x += Math.cos(e.angle) * e.speed;
      e.y += Math.sin(e.angle) * e.speed;
      if (Math.random() < 0.3) spawnEngineTrail(e.x - Math.cos(e.angle) * 12, e.y - Math.sin(e.angle) * 12, e.angle);
      e.fireCooldown -= dt;
      if (e.fireCooldown <= 0 && dist(e, player) < 500) {
        const a = angle(e, player);
        enemyBullets.push({ x: e.x, y: e.y, vx: Math.cos(a) * 6, vy: Math.sin(a) * 6, life: 2, damage: e.damage });
        e.fireCooldown = 0.8;
      }
      if (e.x < -100 || e.x > WORLD_W + 100 || e.y < -100 || e.y > WORLD_H + 100) { enemies.splice(i, 1); continue; }
    }
    if (e.type === "chopper") {
      const d = dist(e, player); const a = angle(e, player);
      e.rotorAngle += dt * 22; e.tailRotorAngle += dt * 35;
      if (d > 200) { e.vx = lerp(e.vx, Math.cos(a) * e.speed, 0.05); e.vy = lerp(e.vy, Math.sin(a) * e.speed, 0.05); }
      else if (d < 120) { e.vx = lerp(e.vx, -Math.cos(a) * e.speed, 0.05); e.vy = lerp(e.vy, -Math.sin(a) * e.speed, 0.05); }
      else { e.vx = lerp(e.vx, Math.cos(a + Math.PI / 2) * e.speed * 0.5, 0.05); e.vy = lerp(e.vy, Math.sin(a + Math.PI / 2) * e.speed * 0.5, 0.05); }
      e.x = clamp(e.x + e.vx, 20, WORLD_W - 20);
      e.y = clamp(e.y + e.vy, 20, WORLD_H - 20);
      e.angle = a;
      e.fireCooldown -= dt;
      if (e.fireCooldown <= 0 && d < 400) { enemyBullets.push({ x: e.x, y: e.y, vx: Math.cos(a) * 5, vy: Math.sin(a) * 5, life: 2.5, damage: e.damage }); e.fireCooldown = 1.2 - wantedLevel * 0.1; }
    }
    for (const rig of rigs) {
      if (rig.owner === "player" && rig.hp > 0 && dist(e, rig) < 60) {
        rig.hp -= 10 * dt;
        if (rig.hp <= 0) { rig.owner = "neutral"; rig.hp = 0; spawnExplosion(rig.x, rig.y, "#ff8800", 25); addShake(6); }
      }
    }
    if (e.hp <= 0) {
      spawnExplosion(e.x, e.y, "#ff4400", 18);
      score += e.scoreValue;
      player.oil = Math.min(OIL_MAX, player.oil + 10 * upgradeStats.oilMult);
      spawnFloatingText(e.x, e.y - 20, "+" + e.scoreValue, "#ffcc00");
      addShake(3);
      enemies.splice(i, 1);
    }
  }

  for (let i = bullets.length - 1; i >= 0; i--) {
    const b = bullets[i];
    b.x += b.vx; b.y += b.vy; b.life -= dt;
    if (b.life <= 0 || b.x < 0 || b.x > WORLD_W || b.y < 0 || b.y > WORLD_H) { bullets.splice(i, 1); continue; }
    for (let j = enemies.length - 1; j >= 0; j--) {
      if (dist(b, enemies[j]) < enemies[j].radius + 6) {
        enemies[j].hp -= b.damage;
        if (b.crit) { spawnExplosion(b.x, b.y, "#ff0000", 6); spawnFloatingText(b.x, b.y - 10, "CRIT!", "#ff4444"); }
        else spawnExplosion(b.x, b.y, "#ffcc00", 4);
        bullets.splice(i, 1); break;
      }
    }
  }

  for (let i = homingMissiles.length - 1; i >= 0; i--) {
    const m = homingMissiles[i];
    m.life -= dt;
    if (m.life <= 0) { spawnExplosion(m.x, m.y, "#ff6600", 8); homingMissiles.splice(i, 1); continue; }
    if (m.target && m.target.hp > 0) {
      const desired = Math.atan2(m.target.y - m.y, m.target.x - m.x);
      let diff = desired - m.angle;
      while (diff > Math.PI) diff -= Math.PI * 2;
      while (diff < -Math.PI) diff += Math.PI * 2;
      m.angle += clamp(diff, -HOMING_TURN, HOMING_TURN);
    } else m.target = findNearestEnemy(m);
    m.x += Math.cos(m.angle) * m.speed;
    m.y += Math.sin(m.angle) * m.speed;
    for (let t = 0; t < 2; t++) {
      const tx = m.x - Math.cos(m.angle) * (6 + t * 4);
      const ty = m.y - Math.sin(m.angle) * (6 + t * 4);
      spawnParticle(tx + rand(-2, 2), ty + rand(-2, 2), rand(-0.5, 0.5), rand(-0.5, 0.5), rand(0.1, 0.3), rand(2, 4), t === 0 ? "#ff6600" : "#ff3300", "fire");
    }
    for (let j = enemies.length - 1; j >= 0; j--) {
      if (dist(m, enemies[j]) < enemies[j].radius + 10) { enemies[j].hp -= m.damage; spawnExplosion(m.x, m.y, "#ff8800", 15); addShake(5); homingMissiles.splice(i, 1); break; }
    }
  }

  for (let i = enemyBullets.length - 1; i >= 0; i--) {
    const b = enemyBullets[i];
    b.x += b.vx; b.y += b.vy; b.life -= dt;
    if (b.life <= 0) { enemyBullets.splice(i, 1); continue; }
    if (dist(b, player) < 18 && player.invincible <= 0) { damagePlayer(b.damage); enemyBullets.splice(i, 1); }
  }

  for (let i = particles.length - 1; i >= 0; i--) {
    const p = particles[i];
    p.x += p.vx; p.y += p.vy; p.vx *= 0.95; p.vy *= 0.95;
    if (p.type === "smoke") p.vy -= 0.02;
    p.life -= dt;
    if (p.life <= 0) particles.splice(i, 1);
  }

  for (let i = floatingTexts.length - 1; i >= 0; i--) {
    floatingTexts[i].y -= 30 * dt;
    floatingTexts[i].life -= dt;
    if (floatingTexts[i].life <= 0) floatingTexts.splice(i, 1);
  }

  shakeAmount *= 0.9;
  if (shakeAmount < 0.1) shakeAmount = 0;
  updateCamera(player);

  if (score >= nextUpgradeScore) {
    nextUpgradeScore += UPGRADE_INTERVAL + totalUpgrades * 100;
    upgradeChoices = getUpgradeChoices();
    if (upgradeChoices.length > 0) gameState = "upgrade";
  }

  if (player.oil <= 0) { player.oil = 0; player.alive = false; gameState = "gameover"; spawnExplosion(player.x, player.y, "#ff2200", 40); addShake(12); }
}

function damagePlayer(amount) {
  if (player.invincible > 0) return;
  if (player.shieldActive) { player.shieldActive = false; spawnExplosion(player.x, player.y, "#aa44ff", 10); spawnFloatingText(player.x, player.y - 25, "SHIELD!", "#aa44ff"); player.invincible = 0.3; return; }
  player.oil -= amount * upgradeStats.armorMult;
  player.invincible = 0.5;
  spawnOilSpill(player.x, player.y);
  addShake(4);
  if (upgradeStats.hasEmp) { for (const e of enemies) { if (dist(player, e) < upgradeStats.empRadius) { e.stunTimer = 1.5; spawnExplosion(e.x, e.y, "#44ffff", 6); } } }
}

/* ===== DRAW ===== */
function draw() {
  ctx.clearRect(0, 0, W, H);
  ctx.save();
  if (shakeAmount > 0) ctx.translate(rand(-shakeAmount, shakeAmount), rand(-shakeAmount, shakeAmount));
  ctx.translate(-camera.x, -camera.y);
  drawWater();
  drawRigs();
  drawShadows();
  drawEnemies();
  drawBullets();
  drawPlayer();
  drawParticles();
  drawFloatingTexts();
  ctx.restore();
  drawHUD();
  drawTouchControls();
}

function drawWater() {
  const sx = Math.floor(camera.x / TILE), sy = Math.floor(camera.y / TILE);
  const ex = Math.ceil((camera.x + W) / TILE), ey = Math.ceil((camera.y + H) / TILE);
  for (let y = sy; y <= ey; y++) {
    for (let x = sx; x <= ex; x++) {
      const w = Math.sin(time * 1.5 + x * 0.5 + y * 0.3) * 0.02;
      const base = (x + y) % 2 === 0 ? 0.15 : 0.18;
      ctx.fillStyle = "rgb(" + clamp(Math.floor((0.04 + w) * 255), 0, 255) + "," + clamp(Math.floor((base + w) * 255), 0, 255) + "," + clamp(Math.floor((0.35 + base + w) * 255), 0, 255) + ")";
      ctx.fillRect(x * TILE, y * TILE, TILE + 1, TILE + 1);
    }
  }
  ctx.globalAlpha = 0.06; ctx.fillStyle = "#88ccff";
  for (let y = sy; y <= ey; y += 2) { ctx.fillRect(sx * TILE + Math.sin(time * 2 + y * 0.4) * 20, y * TILE, (ex - sx) * TILE, 3); }
  ctx.globalAlpha = 0.04;
  for (let i = 0; i < 12; i++) {
    const cx2 = camera.x + (Math.sin(time * 0.3 + i * 2.1) * 0.5 + 0.5) * W;
    const cy2 = camera.y + (Math.cos(time * 0.2 + i * 1.7) * 0.5 + 0.5) * H;
    ctx.fillStyle = "#aaddff"; ctx.beginPath(); ctx.arc(cx2, cy2, 30 + Math.sin(time + i) * 15, 0, Math.PI * 2); ctx.fill();
  }
  ctx.globalAlpha = 1;
}

function drawShadows() {
  ctx.globalAlpha = 0.12; ctx.fillStyle = "#000";
  if (player.alive) { ctx.beginPath(); ctx.ellipse(player.x + 6, player.y + 10, 18, 10, 0.2, 0, Math.PI * 2); ctx.fill(); }
  for (const e of enemies) { const r = e.type === "drone" ? 10 : e.type === "plane" ? 16 : 14; ctx.beginPath(); ctx.ellipse(e.x + 5, e.y + 8, r, r * 0.6, 0.15, 0, Math.PI * 2); ctx.fill(); }
  ctx.globalAlpha = 1;
}

function drawRigs() {
  for (const rig of rigs) {
    if (rig.hp <= 0) {
      ctx.save(); ctx.translate(rig.x, rig.y);
      ctx.fillStyle = "#222"; ctx.fillRect(-18, -18, 36, 36);
      ctx.fillStyle = "#333"; ctx.fillRect(-12, -12, 8, 24); ctx.fillRect(2, -8, 10, 16);
      ctx.globalAlpha = 0.15; ctx.fillStyle = "#444"; ctx.beginPath(); ctx.arc(0, -20, 10, 0, Math.PI * 2); ctx.fill();
      ctx.globalAlpha = 1; ctx.restore(); continue;
    }
    ctx.save(); ctx.translate(rig.x, rig.y);
    // Water ring
    ctx.strokeStyle = "rgba(100,200,255,0.15)"; ctx.lineWidth = 2;
    ctx.beginPath(); ctx.arc(0, 0, 32 + Math.sin(time * 2 + rig.flamePhase) * 3, 0, Math.PI * 2); ctx.stroke();
    // Legs
    ctx.fillStyle = "#555"; ctx.fillRect(-26, -26, 4, 52); ctx.fillRect(22, -26, 4, 52); ctx.fillRect(-26, -26, 52, 4); ctx.fillRect(-26, 22, 52, 4);
    // Deck
    ctx.fillStyle = rig.owner === "player" ? "#2a6644" : "#4a4a4a";
    ctx.fillRect(-22, -22, 44, 44);
    // Grid
    ctx.strokeStyle = rig.owner === "player" ? "rgba(68,255,136,0.2)" : "rgba(255,255,255,0.1)";
    ctx.lineWidth = 0.5;
    for (let gx = -20; gx <= 20; gx += 10) { ctx.beginPath(); ctx.moveTo(gx, -22); ctx.lineTo(gx, 22); ctx.stroke(); }
    for (let gy = -20; gy <= 20; gy += 10) { ctx.beginPath(); ctx.moveTo(-22, gy); ctx.lineTo(22, gy); ctx.stroke(); }
    // Derrick
    ctx.strokeStyle = "#999"; ctx.lineWidth = 2;
    ctx.beginPath(); ctx.moveTo(-6, 0); ctx.lineTo(-3, -28); ctx.lineTo(3, -28); ctx.lineTo(6, 0); ctx.stroke();
    ctx.lineWidth = 1;
    ctx.beginPath(); ctx.moveTo(-5, -7); ctx.lineTo(5, -14); ctx.moveTo(5, -7); ctx.lineTo(-5, -14); ctx.moveTo(-4, -18); ctx.lineTo(4, -24); ctx.moveTo(4, -18); ctx.lineTo(-4, -24); ctx.stroke();
    // Crane
    ctx.save(); ctx.translate(10, -5); ctx.rotate(Math.sin(rig.craneAngle) * 0.3);
    ctx.strokeStyle = "#888"; ctx.lineWidth = 1.5; ctx.beginPath(); ctx.moveTo(0, 0); ctx.lineTo(18, -12); ctx.stroke();
    ctx.strokeStyle = "#666"; ctx.lineWidth = 0.5; ctx.beginPath(); ctx.moveTo(18, -12); ctx.lineTo(18, -2 + Math.sin(time * 3) * 2); ctx.stroke();
    ctx.restore();
    // Flame
    const fs = 4 + Math.sin(rig.flamePhase) * 2;
    ctx.globalAlpha = 0.15; ctx.fillStyle = "#ff6600"; ctx.beginPath(); ctx.arc(0, -30, fs * 2.5, 0, Math.PI * 2); ctx.fill();
    ctx.globalAlpha = 1; ctx.fillStyle = "#ff4400"; ctx.beginPath(); ctx.arc(0, -30, fs, 0, Math.PI * 2); ctx.fill();
    ctx.fillStyle = "#ffcc00"; ctx.beginPath(); ctx.arc(0, -30, fs * 0.5, 0, Math.PI * 2); ctx.fill();
    if (rig.owner === "player") {
      ctx.strokeStyle = "rgba(68,255,136,0.4)"; ctx.lineWidth = 1; ctx.beginPath(); ctx.arc(0, 8, 10, 0, Math.PI * 2); ctx.stroke();
      ctx.font = "bold 8px monospace"; ctx.fillStyle = "rgba(68,255,136,0.5)"; ctx.textAlign = "center"; ctx.fillText("H", 0, 12);
      ctx.strokeStyle = "rgba(68,255,136," + (0.3 + Math.sin(time * 3) * 0.15) + ")"; ctx.lineWidth = 2; ctx.strokeRect(-24, -24, 48, 48);
    }
    ctx.restore();
    // HP bar
    if (rig.owner === "player") {
      const bw = 44; ctx.fillStyle = "rgba(0,0,0,0.5)"; ctx.fillRect(rig.x - bw / 2 - 1, rig.y + 30, bw + 2, 6);
      ctx.fillStyle = "#333"; ctx.fillRect(rig.x - bw / 2, rig.y + 31, bw, 4);
      const hp = rig.hp / rig.maxHp;
      ctx.fillStyle = hp > 0.5 ? "#44ff88" : hp > 0.25 ? "#ffcc00" : "#ff4444";
      ctx.fillRect(rig.x - bw / 2, rig.y + 31, bw * hp, 4);
    }
    if (rig.captureProgress > 0 && rig.owner !== "player") {
      ctx.strokeStyle = "#ffcc00"; ctx.lineWidth = 3;
      ctx.beginPath(); ctx.arc(rig.x, rig.y, CAPTURE_RADIUS, -Math.PI / 2, -Math.PI / 2 + (rig.captureProgress / CAPTURE_TIME) * Math.PI * 2); ctx.stroke();
      ctx.strokeStyle = "rgba(255,204,0,0.3)"; ctx.lineWidth = 1; ctx.setLineDash([6, 6]);
      ctx.beginPath(); ctx.moveTo(player.x, player.y); ctx.lineTo(rig.x, rig.y); ctx.stroke(); ctx.setLineDash([]);
      ctx.font = "bold 12px monospace"; ctx.fillStyle = "#ffcc00"; ctx.textAlign = "center";
      ctx.fillText(Math.floor(rig.captureProgress / CAPTURE_TIME * 100) + "%", rig.x, rig.y - 35);
    }
  }
}

function drawPlayer() {
  if (!player.alive) return;
  const px = player.x, py = player.y, a = player.angle;
  ctx.save(); ctx.translate(px, py); ctx.rotate(a);
  if (player.invincible > 0 && Math.sin(time * 30) > 0) ctx.globalAlpha = 0.4;
  // Tail
  ctx.fillStyle = "#1a4a1a";
  ctx.beginPath(); ctx.moveTo(-8, -2.5); ctx.lineTo(-22, -1.5); ctx.lineTo(-22, 1.5); ctx.lineTo(-8, 2.5); ctx.closePath(); ctx.fill();
  ctx.fillStyle = "#2a6a2a";
  ctx.beginPath(); ctx.moveTo(-22, 0); ctx.lineTo(-26, -6); ctx.lineTo(-20, -1); ctx.closePath(); ctx.fill();
  // Body
  ctx.fillStyle = "#2a5a2a";
  ctx.beginPath(); ctx.moveTo(16, 0); ctx.bezierCurveTo(14, -7, 6, -10, -4, -9); ctx.lineTo(-10, -6); ctx.lineTo(-8, 0); ctx.lineTo(-10, 6); ctx.lineTo(-4, 9); ctx.bezierCurveTo(6, 10, 14, 7, 16, 0); ctx.closePath(); ctx.fill();
  ctx.fillStyle = "rgba(100,180,100,0.3)"; ctx.beginPath(); ctx.ellipse(4, -3, 8, 3, -0.1, 0, Math.PI * 2); ctx.fill();
  // Pylons
  ctx.fillStyle = "#1a3a1a"; ctx.fillRect(-2, -12, 8, 3); ctx.fillRect(-2, 9, 8, 3);
  ctx.fillStyle = "#444"; ctx.fillRect(10, -11.5, 6, 2); ctx.fillRect(10, 9.5, 6, 2);
  // Cockpit
  const grad = ctx.createRadialGradient(10, 0, 0, 10, 0, 6);
  grad.addColorStop(0, "#aaddff"); grad.addColorStop(0.6, "#6699cc"); grad.addColorStop(1, "#335577");
  ctx.fillStyle = grad; ctx.beginPath(); ctx.ellipse(10, 0, 6, 5, 0, 0, Math.PI * 2); ctx.fill();
  ctx.strokeStyle = "#4a8a4a"; ctx.lineWidth = 0.8; ctx.beginPath(); ctx.ellipse(10, 0, 6, 5, 0, 0, Math.PI * 2); ctx.stroke();
  // Intake
  ctx.fillStyle = "#1a3a1a"; ctx.beginPath(); ctx.ellipse(-2, 0, 3, 5, 0, 0, Math.PI * 2); ctx.fill();
  // Exhaust
  if (player.engineGlow > 0.3) { ctx.globalAlpha = (player.engineGlow - 0.3) * 0.5; ctx.fillStyle = "#557799"; ctx.beginPath(); ctx.ellipse(-10, 0, 3, 2, 0, 0, Math.PI * 2); ctx.fill(); ctx.globalAlpha = player.invincible > 0 && Math.sin(time * 30) > 0 ? 0.4 : 1; }
  // Outline
  ctx.strokeStyle = "#4a8a4a"; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(16, 0); ctx.bezierCurveTo(14, -7, 6, -10, -4, -9); ctx.lineTo(-10, -6); ctx.lineTo(-8, 0); ctx.lineTo(-10, 6); ctx.lineTo(-4, 9); ctx.bezierCurveTo(6, 10, 14, 7, 16, 0); ctx.stroke();
  ctx.restore();
  // Main rotor
  ctx.save(); ctx.translate(px, py); ctx.rotate(player.rotorAngle);
  ctx.globalAlpha = 0.06; ctx.fillStyle = "#ccc"; ctx.beginPath(); ctx.arc(0, 0, 20, 0, Math.PI * 2); ctx.fill();
  ctx.globalAlpha = 0.6; ctx.strokeStyle = "#ddd"; ctx.lineWidth = 2.5;
  ctx.beginPath(); ctx.moveTo(-20, 0); ctx.lineTo(20, 0); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(0, -20); ctx.lineTo(0, 20); ctx.stroke();
  ctx.fillStyle = "#ff4400"; ctx.globalAlpha = 0.8;
  ctx.beginPath(); ctx.arc(-20, 0, 1.5, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.arc(20, 0, 1.5, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.arc(0, -20, 1.5, 0, Math.PI * 2); ctx.fill();
  ctx.beginPath(); ctx.arc(0, 20, 1.5, 0, Math.PI * 2); ctx.fill();
  ctx.globalAlpha = 1; ctx.fillStyle = "#888"; ctx.beginPath(); ctx.arc(0, 0, 2.5, 0, Math.PI * 2); ctx.fill();
  ctx.restore();
  // Tail rotor
  ctx.save(); ctx.translate(px, py); ctx.rotate(a); ctx.translate(-22, -5); ctx.rotate(player.tailRotorAngle);
  ctx.globalAlpha = 0.5; ctx.strokeStyle = "#ccc"; ctx.lineWidth = 1.5;
  ctx.beginPath(); ctx.moveTo(-5, 0); ctx.lineTo(5, 0); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(0, -5); ctx.lineTo(0, 5); ctx.stroke();
  ctx.restore(); ctx.globalAlpha = 1;
  // Shield
  if (player.shieldActive) {
    ctx.save(); ctx.translate(px, py);
    ctx.globalAlpha = 0.15 + Math.sin(time * 6) * 0.08;
    ctx.strokeStyle = "#aa44ff"; ctx.lineWidth = 2; ctx.beginPath(); ctx.arc(0, 0, 24, 0, Math.PI * 2); ctx.stroke();
    ctx.fillStyle = "rgba(170,68,255,0.05)"; ctx.fill(); ctx.restore();
  }
}

function drawEnemies() {
  for (const e of enemies) {
    if (e.stunTimer > 0) {
      ctx.save(); ctx.translate(e.x, e.y); ctx.globalAlpha = 0.3; ctx.strokeStyle = "#44ffff"; ctx.lineWidth = 1;
      for (let s = 0; s < 3; s++) { const sa = Math.random() * Math.PI * 2; const sr = rand(8, 16); ctx.beginPath(); ctx.moveTo(0, 0); ctx.lineTo(Math.cos(sa) * sr, Math.sin(sa) * sr); ctx.stroke(); }
      ctx.globalAlpha = 1; ctx.restore();
    }
    if (e.type === "drone") drawDrone(e);
    else if (e.type === "plane") drawPlaneE(e);
    else if (e.type === "chopper") drawChopperE(e);
    if (e.hp < e.maxHp) {
      const bw = e.type === "chopper" ? 30 : 24;
      ctx.fillStyle = "rgba(0,0,0,0.5)"; ctx.fillRect(e.x - bw / 2 - 1, e.y - 24, bw + 2, 5);
      ctx.fillStyle = "#222"; ctx.fillRect(e.x - bw / 2, e.y - 23, bw, 3);
      const hp = e.hp / e.maxHp;
      ctx.fillStyle = hp > 0.5 ? "#ff6644" : "#ff2222";
      ctx.fillRect(e.x - bw / 2, e.y - 23, bw * hp, 3);
    }
  }
}

function drawDrone(e) {
  ctx.save(); ctx.translate(e.x, e.y); ctx.rotate(e.angle);
  ctx.strokeStyle = "#991111"; ctx.lineWidth = 2;
  ctx.beginPath(); ctx.moveTo(-9, -9); ctx.lineTo(9, 9); ctx.moveTo(9, -9); ctx.lineTo(-9, 9); ctx.stroke();
  ctx.fillStyle = "#cc2222"; ctx.beginPath(); ctx.arc(0, 0, 5, 0, Math.PI * 2); ctx.fill();
  ctx.fillStyle = "#dd4444"; ctx.beginPath(); ctx.arc(0, -1, 3, 0, Math.PI * 2); ctx.fill();
  ctx.fillStyle = "rgba(255," + (100 + Math.sin(time * 8) * 50) + ",0,0.9)";
  ctx.beginPath(); ctx.arc(3, 0, 1.5, 0, Math.PI * 2); ctx.fill();
  ctx.restore();
  const offsets = [[-9, -9], [9, -9], [-9, 9], [9, 9]];
  for (const [ox, oy] of offsets) {
    const rx = e.x + Math.cos(e.angle) * ox - Math.sin(e.angle) * oy;
    const ry = e.y + Math.sin(e.angle) * ox + Math.cos(e.angle) * oy;
    ctx.save(); ctx.translate(rx, ry); ctx.rotate(e.rotorAngle);
    ctx.globalAlpha = 0.4; ctx.strokeStyle = "#ff6666"; ctx.lineWidth = 1.5;
    ctx.beginPath(); ctx.moveTo(-6, 0); ctx.lineTo(6, 0); ctx.stroke();
    ctx.globalAlpha = 0.08; ctx.fillStyle = "#ff6666"; ctx.beginPath(); ctx.arc(0, 0, 6, 0, Math.PI * 2); ctx.fill();
    ctx.globalAlpha = 1; ctx.restore();
  }
}

function drawPlaneE(e) {
  ctx.save(); ctx.translate(e.x, e.y); ctx.rotate(e.angle);
  ctx.fillStyle = "#777";
  ctx.beginPath(); ctx.moveTo(18, 0); ctx.bezierCurveTo(16, -3, 4, -5, -8, -4); ctx.lineTo(-14, -2); ctx.lineTo(-14, 2); ctx.lineTo(-8, 4); ctx.bezierCurveTo(4, 5, 16, 3, 18, 0); ctx.closePath(); ctx.fill();
  ctx.fillStyle = "#888";
  ctx.beginPath(); ctx.moveTo(2, -4); ctx.lineTo(-6, -16); ctx.lineTo(-10, -16); ctx.lineTo(-4, -4); ctx.closePath(); ctx.fill();
  ctx.beginPath(); ctx.moveTo(2, 4); ctx.lineTo(-6, 16); ctx.lineTo(-10, 16); ctx.lineTo(-4, 4); ctx.closePath(); ctx.fill();
  ctx.fillStyle = "#cc0000"; ctx.fillRect(-9, -17, 3, 2); ctx.fillRect(-9, 15, 3, 2);
  ctx.fillStyle = "#666";
  ctx.beginPath(); ctx.moveTo(-12, -2); ctx.lineTo(-16, -8); ctx.lineTo(-18, -8); ctx.lineTo(-14, -2); ctx.closePath(); ctx.fill();
  ctx.beginPath(); ctx.moveTo(-12, 2); ctx.lineTo(-16, 8); ctx.lineTo(-18, 8); ctx.lineTo(-14, 2); ctx.closePath(); ctx.fill();
  ctx.beginPath(); ctx.moveTo(-12, 0); ctx.lineTo(-17, -5); ctx.lineTo(-14, 0); ctx.closePath(); ctx.fill();
  ctx.fillStyle = "#44aadd"; ctx.beginPath(); ctx.ellipse(12, 0, 4, 2.5, 0, 0, Math.PI * 2); ctx.fill();
  ctx.fillStyle = "#cc0000"; ctx.fillRect(0, -1.5, 10, 3);
  ctx.globalAlpha = 0.5; ctx.fillStyle = "#ffaa44"; ctx.beginPath(); ctx.ellipse(-14, 0, 2, 1.5, 0, 0, Math.PI * 2); ctx.fill(); ctx.globalAlpha = 1;
  ctx.save(); ctx.translate(18, 0); ctx.rotate(e.propAngle || 0);
  ctx.globalAlpha = 0.5; ctx.strokeStyle = "#aaa"; ctx.lineWidth = 1.5;
  ctx.beginPath(); ctx.moveTo(-5, 0); ctx.lineTo(5, 0); ctx.stroke(); ctx.globalAlpha = 1; ctx.restore();
  ctx.restore();
}

function drawChopperE(e) {
  ctx.save(); ctx.translate(e.x, e.y); ctx.rotate(e.angle);
  ctx.fillStyle = "#6a2020"; ctx.beginPath(); ctx.moveTo(-6, -2); ctx.lineTo(-20, -1); ctx.lineTo(-20, 1); ctx.lineTo(-6, 2); ctx.closePath(); ctx.fill();
  ctx.fillStyle = "#8a3030"; ctx.beginPath(); ctx.moveTo(-20, 0); ctx.lineTo(-24, -5); ctx.lineTo(-18, -1); ctx.closePath(); ctx.fill();
  ctx.fillStyle = "#993333";
  ctx.beginPath(); ctx.moveTo(14, 0); ctx.bezierCurveTo(12, -6, 4, -9, -4, -7); ctx.lineTo(-8, -4); ctx.lineTo(-6, 0); ctx.lineTo(-8, 4); ctx.lineTo(-4, 7); ctx.bezierCurveTo(4, 9, 12, 6, 14, 0); ctx.closePath(); ctx.fill();
  ctx.fillStyle = "rgba(200,100,100,0.3)"; ctx.beginPath(); ctx.ellipse(4, -2, 6, 2.5, -0.1, 0, Math.PI * 2); ctx.fill();
  ctx.fillStyle = "#662222"; ctx.fillRect(0, -10, 6, 2.5); ctx.fillRect(0, 7.5, 6, 2.5);
  ctx.fillStyle = "#ffaa44"; ctx.beginPath(); ctx.ellipse(8, 0, 5, 3.5, 0, 0, Math.PI * 2); ctx.fill();
  ctx.strokeStyle = "#cc6633"; ctx.lineWidth = 0.8; ctx.beginPath(); ctx.ellipse(8, 0, 5, 3.5, 0, 0, Math.PI * 2); ctx.stroke();
  ctx.strokeStyle = "#bb4444"; ctx.lineWidth = 0.8;
  ctx.beginPath(); ctx.moveTo(14, 0); ctx.bezierCurveTo(12, -6, 4, -9, -4, -7); ctx.lineTo(-8, -4); ctx.lineTo(-6, 0); ctx.lineTo(-8, 4); ctx.lineTo(-4, 7); ctx.bezierCurveTo(4, 9, 12, 6, 14, 0); ctx.stroke();
  ctx.restore();
  // Main rotor
  ctx.save(); ctx.translate(e.x, e.y); ctx.rotate(e.rotorAngle || 0);
  ctx.globalAlpha = 0.07; ctx.fillStyle = "#ff9999"; ctx.beginPath(); ctx.arc(0, 0, 18, 0, Math.PI * 2); ctx.fill();
  ctx.globalAlpha = 0.5; ctx.strokeStyle = "#ff8888"; ctx.lineWidth = 2;
  ctx.beginPath(); ctx.moveTo(-18, 0); ctx.lineTo(18, 0); ctx.stroke();
  ctx.beginPath(); ctx.moveTo(0, -18); ctx.lineTo(0, 18); ctx.stroke();
  ctx.globalAlpha = 1; ctx.fillStyle = "#666"; ctx.beginPath(); ctx.arc(0, 0, 2, 0, Math.PI * 2); ctx.fill();
  ctx.restore();
  // Tail rotor
  ctx.save(); ctx.translate(e.x, e.y); ctx.rotate(e.angle); ctx.translate(-20, -4); ctx.rotate(e.tailRotorAngle || 0);
  ctx.globalAlpha = 0.4; ctx.strokeStyle = "#ff8888"; ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(-4, 0); ctx.lineTo(4, 0); ctx.stroke(); ctx.globalAlpha = 1; ctx.restore();
}

function drawBullets() {
  for (const b of bullets) {
    ctx.save(); ctx.translate(b.x, b.y);
    ctx.globalAlpha = 0.3; ctx.fillStyle = b.crit ? "#ff4444" : "#ffee55"; ctx.beginPath(); ctx.arc(0, 0, 6, 0, Math.PI * 2); ctx.fill();
    ctx.globalAlpha = 1; ctx.fillStyle = b.crit ? "#ff6666" : "#ffee88"; ctx.beginPath(); ctx.arc(0, 0, 3, 0, Math.PI * 2); ctx.fill();
    ctx.fillStyle = "#fff"; ctx.beginPath(); ctx.arc(0, 0, 1.5, 0, Math.PI * 2); ctx.fill();
    ctx.restore();
  }
  for (const b of enemyBullets) {
    ctx.save(); ctx.translate(b.x, b.y);
    ctx.globalAlpha = 0.3; ctx.fillStyle = "#ff3333"; ctx.beginPath(); ctx.arc(0, 0, 8, 0, Math.PI * 2); ctx.fill();
    ctx.globalAlpha = 1; ctx.fillStyle = "#ff4444"; ctx.beginPath(); ctx.arc(0, 0, 4, 0, Math.PI * 2); ctx.fill();
    ctx.fillStyle = "#ffaa88"; ctx.beginPath(); ctx.arc(0, 0, 2, 0, Math.PI * 2); ctx.fill();
    ctx.restore();
  }
  for (const m of homingMissiles) {
    ctx.save(); ctx.translate(m.x, m.y); ctx.rotate(m.angle);
    ctx.fillStyle = "#dd6600";
    ctx.beginPath(); ctx.moveTo(8, 0); ctx.lineTo(-4, -3); ctx.lineTo(-6, -3); ctx.lineTo(-6, 3); ctx.lineTo(-4, 3); ctx.closePath(); ctx.fill();
    ctx.fillStyle = "#ff8800"; ctx.beginPath(); ctx.arc(6, 0, 2.5, -Math.PI / 2, Math.PI / 2); ctx.fill();
    ctx.fillStyle = "#aa4400"; ctx.fillRect(-6, -5, 3, 2); ctx.fillRect(-6, 3, 3, 2);
    ctx.fillStyle = "#ffaa00"; ctx.beginPath(); ctx.arc(-7, 0, 2 + Math.sin(time * 30) * 0.5, 0, Math.PI * 2); ctx.fill();
    ctx.restore();
  }
}

function drawParticles() {
  for (const p of particles) {
    const alpha = clamp(p.life / p.maxLife, 0, 1);
    if (p.type === "smoke") {
      ctx.globalAlpha = alpha * 0.5; ctx.fillStyle = p.color; ctx.beginPath(); ctx.arc(p.x, p.y, p.r * (2 - alpha), 0, Math.PI * 2); ctx.fill();
    } else if (p.type === "fire") {
      ctx.globalAlpha = alpha * 0.3; ctx.fillStyle = "#ff6600"; ctx.beginPath(); ctx.arc(p.x, p.y, p.r * 2, 0, Math.PI * 2); ctx.fill();
      ctx.globalAlpha = alpha; ctx.fillStyle = p.color; ctx.beginPath(); ctx.arc(p.x, p.y, p.r * alpha, 0, Math.PI * 2); ctx.fill();
    } else if (p.type === "oil") {
      ctx.globalAlpha = alpha * 0.7; ctx.fillStyle = p.color; ctx.beginPath(); ctx.arc(p.x, p.y, p.r * (1.5 - alpha * 0.5), 0, Math.PI * 2); ctx.fill();
    } else {
      ctx.globalAlpha = alpha; ctx.fillStyle = p.color; ctx.beginPath(); ctx.arc(p.x, p.y, p.r * alpha, 0, Math.PI * 2); ctx.fill();
    }
  }
  ctx.globalAlpha = 1;
}

function drawFloatingTexts() {
  for (const ft of floatingTexts) {
    const alpha = clamp(ft.life / ft.maxLife, 0, 1);
    ctx.globalAlpha = alpha; ctx.font = "bold 13px monospace"; ctx.textAlign = "center";
    ctx.fillStyle = "rgba(0,0,0,0.5)"; ctx.fillText(ft.text, ft.x + 1, ft.y + 1);
    ctx.fillStyle = ft.color; ctx.fillText(ft.text, ft.x, ft.y);
  }
  ctx.globalAlpha = 1;
}

function drawHUD() {
  const pad = 16, barW = Math.min(240, W * 0.35), barH = 20;
  // Panel
  ctx.fillStyle = "rgba(0,0,0,0.5)";
  if (ctx.roundRect) { ctx.beginPath(); ctx.roundRect(pad - 6, pad - 6, barW + 16, 70 + (totalUpgrades > 0 ? 18 : 0), 8); ctx.fill(); }
  else ctx.fillRect(pad - 6, pad - 6, barW + 16, 70 + (totalUpgrades > 0 ? 18 : 0));
  // Oil bar
  const oilPct = player.oil / OIL_MAX;
  ctx.fillStyle = "#111";
  if (ctx.roundRect) { ctx.beginPath(); ctx.roundRect(pad, pad, barW, barH, 4); ctx.fill(); }
  else ctx.fillRect(pad, pad, barW, barH);
  const oilColor = oilPct > 0.5 ? "#44dd44" : oilPct > 0.25 ? "#dddd44" : "#dd4444";
  ctx.fillStyle = oilColor;
  if (ctx.roundRect) { ctx.beginPath(); ctx.roundRect(pad, pad, Math.max(0, barW * oilPct), barH, 4); ctx.fill(); }
  else ctx.fillRect(pad, pad, Math.max(0, barW * oilPct), barH);
  ctx.fillStyle = "#fff"; ctx.font = "bold 12px monospace"; ctx.textAlign = "left";
  ctx.fillText("OIL: " + Math.floor(player.oil) + " / " + OIL_MAX, pad + 4, pad + 15);
  // Score
  ctx.textAlign = "right"; ctx.font = "bold 18px monospace"; ctx.fillStyle = "#ffcc00";
  ctx.fillText("" + score, W - pad, pad + 18);
  ctx.font = "10px monospace"; ctx.fillStyle = "#aaa"; ctx.fillText("SCORE", W - pad, pad + 30);
  // Wanted
  if (wantedLevel > 0) {
    ctx.font = "bold 14px monospace"; ctx.fillStyle = "#ff4444"; ctx.textAlign = "right";
    let s = "WANTED "; for (let i = 0; i < wantedLevel; i++) s += "\u2605"; for (let i = wantedLevel; i < WANTED_THRESHOLDS.length - 1; i++) s += "\u2606";
    ctx.fillText(s, W - pad, pad + 46);
  }
  // Weapons
  ctx.textAlign = "left"; ctx.font = "11px monospace";
  let wy = pad + barH + 10;
  ctx.fillStyle = player.oil >= DUAL_CANNON_THRESHOLD ? "#44ff88" : "#555";
  ctx.fillText("DUAL CANNONS" + (player.oil >= DUAL_CANNON_THRESHOLD ? " \u2713" : ""), pad, wy);
  wy += 14;
  ctx.fillStyle = player.oil >= HOMING_THRESHOLD ? "#ff8844" : "#555";
  ctx.fillText("MISSILES" + (player.oil >= HOMING_THRESHOLD ? " [E/RMB] \u2713" : " (" + HOMING_THRESHOLD + ")"), pad, wy);
  // Upgrades
  if (totalUpgrades > 0) {
    wy += 16; ctx.font = "10px monospace"; ctx.fillStyle = "#888";
    let ut = "UPGRADES: ";
    for (const [k, l] of Object.entries(upgradeLevels)) { if (l > 0) ut += UPGRADES[k].icon + "x" + l + " "; }
    ctx.fillText(ut, pad, wy);
  }
  // Shield
  if (upgradeStats.hasShield) {
    ctx.textAlign = "right"; ctx.font = "12px monospace";
    if (player.shieldActive) { ctx.fillStyle = "#aa44ff"; ctx.fillText("SHIELD READY", W - pad, H - 60); }
    else { ctx.fillStyle = "#555"; ctx.fillText("SHIELD " + Math.ceil(player.shieldTimer) + "s", W - pad, H - 60); }
  }
  // Minimap
  const mmSize = Math.min(130, W * 0.2), mmX = W - mmSize - pad, mmY = H - mmSize - pad;
  ctx.fillStyle = "rgba(0,15,30,0.75)";
  if (ctx.roundRect) { ctx.beginPath(); ctx.roundRect(mmX - 3, mmY - 3, mmSize + 6, mmSize + 6, 6); ctx.fill(); }
  else ctx.fillRect(mmX - 3, mmY - 3, mmSize + 6, mmSize + 6);
  ctx.strokeStyle = "rgba(68,102,136,0.5)"; ctx.lineWidth = 1;
  ctx.strokeRect(mmX - 3, mmY - 3, mmSize + 6, mmSize + 6);
  const mmScale = mmSize / WORLD_W;
  for (const rig of rigs) {
    ctx.fillStyle = rig.hp <= 0 ? "#333" : rig.owner === "player" ? "#44ff88" : "#888";
    ctx.fillRect(mmX + rig.x * mmScale - 2, mmY + rig.y * mmScale - 2, rig.hp <= 0 ? 3 : 5, rig.hp <= 0 ? 3 : 5);
  }
  ctx.fillStyle = "#ff4444";
  for (const e of enemies) ctx.fillRect(mmX + e.x * mmScale - 1, mmY + e.y * mmScale - 1, 2, 2);
  ctx.fillStyle = "#44ff44"; ctx.beginPath(); ctx.arc(mmX + player.x * mmScale, mmY + player.y * mmScale, 3, 0, Math.PI * 2); ctx.fill();
  // Upgrade progress
  ctx.fillStyle = "rgba(0,0,0,0.4)"; ctx.fillRect(mmX, mmY - 14, mmSize, 8);
  const prevThresh = nextUpgradeScore - UPGRADE_INTERVAL - (totalUpgrades > 0 ? (totalUpgrades - 1) * 100 : 0);
  const upPct = clamp((score - Math.max(0, prevThresh)) / Math.max(1, nextUpgradeScore - Math.max(0, prevThresh)), 0, 1);
  ctx.fillStyle = "#aa44ff"; ctx.fillRect(mmX, mmY - 14, mmSize * upPct, 8);
  ctx.font = "7px monospace"; ctx.fillStyle = "#ddd"; ctx.textAlign = "center";
  ctx.fillText("NEXT UPGRADE", mmX + mmSize / 2, mmY - 7);
}

function drawTouchControls() {
  if (!("ontouchstart" in window)) return;
  ctx.fillStyle = "rgba(255,255,255,0.03)"; ctx.fillRect(0, 0, W * 0.5, H);
  if (joystickCenter) {
    ctx.strokeStyle = "rgba(255,255,255,0.15)"; ctx.lineWidth = 2;
    ctx.beginPath(); ctx.arc(joystickCenter.x, joystickCenter.y, JOYSTICK_RADIUS, 0, Math.PI * 2); ctx.stroke();
    ctx.strokeStyle = "rgba(255,255,255,0.08)";
    ctx.beginPath(); ctx.arc(joystickCenter.x, joystickCenter.y, JOYSTICK_RADIUS * 0.5, 0, Math.PI * 2); ctx.stroke();
    const kx = joystickCenter.x + touchMove.x * JOYSTICK_RADIUS;
    const ky = joystickCenter.y + touchMove.y * JOYSTICK_RADIUS;
    ctx.fillStyle = "rgba(255,255,255,0.3)"; ctx.beginPath(); ctx.arc(kx, ky, 22, 0, Math.PI * 2); ctx.fill();
  }
  const bs = 55, bx = W - bs - 30, by = H - bs - 40;
  ctx.strokeStyle = touchFire ? "rgba(255,200,0,0.6)" : "rgba(255,255,255,0.2)"; ctx.lineWidth = 2;
  ctx.beginPath(); ctx.arc(bx, by, bs / 2, 0, Math.PI * 2); ctx.stroke();
  ctx.fillStyle = "rgba(255,255,255,0.25)"; ctx.font = "bold 14px monospace"; ctx.textAlign = "center";
  ctx.fillText("FIRE", bx, by + 5);
  if (player.oil >= HOMING_THRESHOLD) {
    const my2 = H * 0.35;
    ctx.strokeStyle = touchMissile ? "rgba(255,130,0,0.6)" : "rgba(255,130,0,0.2)";
    ctx.beginPath(); ctx.arc(bx, my2, bs / 2, 0, Math.PI * 2); ctx.stroke();
    ctx.fillStyle = "rgba(255,130,0,0.3)"; ctx.fillText("MSL", bx, my2 + 5);
  }
}

function drawUpgradeScreen() {
  ctx.fillStyle = "rgba(0,0,10,0.85)"; ctx.fillRect(0, 0, W, H);
  ctx.textAlign = "center"; ctx.fillStyle = "#ffcc00";
  ctx.font = "bold " + Math.min(36, W * 0.06) + "px monospace";
  ctx.fillText("CHOOSE AN UPGRADE", W / 2, H * 0.15);
  ctx.fillStyle = "#aaa"; ctx.font = Math.min(14, W * 0.025) + "px monospace";
  ctx.fillText("Score: " + score + " | Upgrades: " + totalUpgrades, W / 2, H * 0.22);
  const cardW = Math.min(200, W * 0.28), cardH = Math.min(260, H * 0.45), gap = Math.min(30, W * 0.03);
  const totalW = upgradeChoices.length * cardW + (upgradeChoices.length - 1) * gap;
  const startX = (W - totalW) / 2, startY = (H - cardH) / 2;
  for (let i = 0; i < upgradeChoices.length; i++) {
    const key = upgradeChoices[i], up = UPGRADES[key], lvl = upgradeLevels[key] || 0;
    const cx = startX + i * (cardW + gap), cy = startY;
    ctx.fillStyle = "rgba(20,20,40,0.9)";
    if (ctx.roundRect) { ctx.beginPath(); ctx.roundRect(cx, cy, cardW, cardH, 12); ctx.fill(); }
    else ctx.fillRect(cx, cy, cardW, cardH);
    ctx.strokeStyle = up.color + "88"; ctx.lineWidth = 2;
    if (ctx.roundRect) { ctx.beginPath(); ctx.roundRect(cx, cy, cardW, cardH, 12); ctx.stroke(); }
    else ctx.strokeRect(cx, cy, cardW, cardH);
    if (mouseX >= cx && mouseX <= cx + cardW && mouseY >= cy && mouseY <= cy + cardH) {
      ctx.fillStyle = up.color + "15";
      if (ctx.roundRect) { ctx.beginPath(); ctx.roundRect(cx, cy, cardW, cardH, 12); ctx.fill(); }
      else ctx.fillRect(cx, cy, cardW, cardH);
      ctx.strokeStyle = up.color; ctx.lineWidth = 2;
      if (ctx.roundRect) { ctx.beginPath(); ctx.roundRect(cx, cy, cardW, cardH, 12); ctx.stroke(); }
      else ctx.strokeRect(cx, cy, cardW, cardH);
    }
    ctx.font = Math.min(40, cardW * 0.25) + "px serif"; ctx.textAlign = "center"; ctx.fillStyle = "#fff";
    ctx.fillText(up.icon, cx + cardW / 2, cy + cardH * 0.25);
    ctx.font = "bold " + Math.min(16, cardW * 0.09) + "px monospace"; ctx.fillStyle = up.color;
    ctx.fillText(up.name, cx + cardW / 2, cy + cardH * 0.42);
    ctx.font = Math.min(12, cardW * 0.07) + "px monospace"; ctx.fillStyle = "#888";
    let dots = ""; for (let d = 0; d < up.maxLevel; d++) dots += d < lvl ? "\u25CF" : d === lvl ? "\u25C9" : "\u25CB";
    ctx.fillText(dots, cx + cardW / 2, cy + cardH * 0.52);
    ctx.font = Math.min(12, cardW * 0.065) + "px monospace"; ctx.fillStyle = "#bbb";
    ctx.fillText(up.desc, cx + cardW / 2, cy + cardH * 0.65);
    ctx.font = Math.min(11, cardW * 0.06) + "px monospace"; ctx.fillStyle = "#666";
    ctx.fillText("Level " + lvl + " \u2192 " + (lvl + 1), cx + cardW / 2, cy + cardH * 0.78);
    ctx.font = "bold " + Math.min(12, cardW * 0.065) + "px monospace"; ctx.fillStyle = up.color + "88";
    ctx.fillText("[ CLICK ]", cx + cardW / 2, cy + cardH * 0.9);
  }
}

function drawTitle() {
  const grad = ctx.createLinearGradient(0, 0, 0, H);
  grad.addColorStop(0, "#060d1a"); grad.addColorStop(0.5, "#0a1a2a"); grad.addColorStop(1, "#0d2240");
  ctx.fillStyle = grad; ctx.fillRect(0, 0, W, H);
  const t = performance.now() / 1000;
  for (let i = 0; i < 30; i++) {
    ctx.globalAlpha = 0.015 + Math.sin(t + i) * 0.008;
    ctx.fillStyle = i % 3 === 0 ? "#ff8800" : i % 3 === 1 ? "#ff4400" : "#ffcc00";
    ctx.beginPath(); ctx.arc((Math.sin(t * 0.3 + i * 2.1) * 0.5 + 0.5) * W, (Math.cos(t * 0.15 + i * 0.9) * 0.5 + 0.5) * H, 20 + Math.sin(t + i * 0.7) * 15, 0, Math.PI * 2); ctx.fill();
  }
  ctx.globalAlpha = 0.04; ctx.strokeStyle = "#4488cc"; ctx.lineWidth = 1;
  for (let i = 0; i < 10; i++) {
    ctx.beginPath();
    for (let x = 0; x <= W; x += 20) { const y = H * 0.5 + i * 30 + Math.sin(t * 1.5 + x * 0.01 + i) * 15; if (x === 0) ctx.moveTo(x, y); else ctx.lineTo(x, y); }
    ctx.stroke();
  }
  ctx.globalAlpha = 1; ctx.textAlign = "center";
  ctx.fillStyle = "#ff8800"; ctx.font = "bold " + Math.min(52, W * 0.085) + "px monospace";
  ctx.fillText("BLACK GOLD BLITZ", W / 2, H * 0.22);
  ctx.fillStyle = "#ffcc44"; ctx.font = Math.min(16, W * 0.03) + "px monospace";
  ctx.fillText("TOP-DOWN ARCADE SHOOTER", W / 2, H * 0.29);
  ctx.fillStyle = "#aaa"; ctx.font = Math.min(13, W * 0.025) + "px monospace";
  const features = [
    "WASD/Arrows - Move  |  Mouse - Aim  |  Space/LMB - Fire",
    "E/RMB - Homing Missiles (1000+ oil)",
    "",
    "Capture oil rigs - Oil = Health + Power",
    "Earn upgrades every 500 score - Choose abilities",
    "Higher oil = Higher wanted = Tougher enemies",
    "",
    "Touch: Left = Move  |  Right = Fire / Missile",
  ];
  features.forEach((l, i) => ctx.fillText(l, W / 2, H * 0.38 + i * Math.min(22, W * 0.035)));
  ctx.fillStyle = "#aa44ff"; ctx.font = "bold " + Math.min(14, W * 0.025) + "px monospace";
  ctx.fillText("10 UNIQUE UPGRADES TO DISCOVER", W / 2, H * 0.73);
  const icons = Object.values(UPGRADES).map(u => u.icon).join("  ");
  ctx.font = Math.min(18, W * 0.03) + "px serif"; ctx.fillText(icons, W / 2, H * 0.78);
  ctx.fillStyle = Math.sin(t * 3) > 0 ? "#ffcc00" : "#ff8800";
  ctx.font = "bold " + Math.min(24, W * 0.04) + "px monospace";
  ctx.fillText("[ CLICK or TAP to START ]", W / 2, H * 0.9);
}

function drawGameOver() {
  ctx.fillStyle = "rgba(0,0,0,0.75)"; ctx.fillRect(0, 0, W, H);
  ctx.textAlign = "center";
  ctx.fillStyle = "#ff3333"; ctx.font = "bold " + Math.min(52, W * 0.085) + "px monospace";
  ctx.fillText("GAME OVER", W / 2, H * 0.28);
  ctx.fillStyle = "#ffcc00"; ctx.font = "bold " + Math.min(32, W * 0.055) + "px monospace";
  ctx.fillText("FINAL SCORE: " + score, W / 2, H * 0.4);
  ctx.fillStyle = "#aaa"; ctx.font = Math.min(14, W * 0.025) + "px monospace";
  ctx.fillText("Oil Rigs: " + rigs.filter(r => r.owner === "player").length + "/" + RIG_COUNT, W / 2, H * 0.48);
  ctx.fillText("Upgrades: " + totalUpgrades, W / 2, H * 0.53);
  let ws = "Wanted: "; for (let i = 0; i < wantedLevel; i++) ws += "\u2605"; for (let i = wantedLevel; i < WANTED_THRESHOLDS.length - 1; i++) ws += "\u2606";
  ctx.fillText(ws, W / 2, H * 0.58);
  if (totalUpgrades > 0) {
    ctx.fillStyle = "#888"; ctx.font = Math.min(12, W * 0.022) + "px monospace";
    let ut = "Abilities: "; for (const [k, l] of Object.entries(upgradeLevels)) { if (l > 0) ut += UPGRADES[k].icon + " " + UPGRADES[k].name + " Lv" + l + "  "; }
    ctx.fillText(ut, W / 2, H * 0.64);
  }
  const t = performance.now() / 1000;
  ctx.fillStyle = Math.sin(t * 3) > 0 ? "#ffcc00" : "#ff8800";
  ctx.font = "bold " + Math.min(22, W * 0.04) + "px monospace";
  ctx.fillText("[ CLICK or TAP to RESTART ]", W / 2, H * 0.78);
}

function startGame() {
  score = 0; waveTimer = 2; wantedLevel = 0; time = 0;
  enemies.length = 0; bullets.length = 0; enemyBullets.length = 0;
  homingMissiles.length = 0; particles.length = 0; floatingTexts.length = 0;
  shakeAmount = 0;
  resetPlayer(); resetUpgrades(); initRigs();
  gameState = "playing";
}

canvas.addEventListener("click", (e) => {
  if (gameState === "title" || gameState === "gameover") startGame();
  else if (gameState === "upgrade") handleUpgradeClick(e.clientX, e.clientY);
});
canvas.addEventListener("touchstart", (e) => {
  if (gameState === "title" || gameState === "gameover") { startGame(); e.preventDefault(); }
}, { passive: false, once: false });

let lastTime = performance.now();
function gameLoop(now) {
  const dt = Math.min((now - lastTime) / 1000, MAX_DELTA_TIME);
  lastTime = now;
  if (gameState === "playing") { update(dt); draw(); }
  else if (gameState === "title") drawTitle();
  else if (gameState === "gameover") { draw(); drawGameOver(); }
  else if (gameState === "upgrade") { draw(); drawUpgradeScreen(); }
  requestAnimationFrame(gameLoop);
}
requestAnimationFrame(gameLoop);
</script>
</body>
</html>